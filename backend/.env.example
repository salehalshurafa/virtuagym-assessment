# Copy this file to .env and fill in values for your environment.
# .env is git-ignored. Never commit secrets.

# ----- Database -----
# Local dev (Postgres on localhost):
#   DATABASE_URL=postgresql+psycopg://virtuagym:virtuagym@localhost:5432/virtuagym
# Remote (e.g. Postgres on a GCP VM):
#   DATABASE_URL=postgresql+psycopg://virtuagym:CHANGE_ME@1.2.3.4:5432/virtuagym?sslmode=require
DATABASE_URL=postgresql+psycopg://virtuagym:CHANGE_ME@X.X.X.X:5432/virtuagym

# ----- API -----
# Origins allowed by CORS, comma-separated. The Vite dev server defaults to 5173.
CORS_ORIGINS=http://localhost:5173

# Where uploaded images are written (relative to the backend/ folder).
UPLOADS_DIR=uploads

# ----- Auth -----
# Set Secure flag on the session cookie. true in production over HTTPS.
COOKIE_SECURE=false

# ----- Email -----
# When false, the LogMailer is used and emails are written to the app log only.
EMAILS_ENABLED=false

# SMTP target. Defaults below match the docker-compose Mailpit service.
# Swap host/port/credentials for AWS SES, Gmail SMTP, SendGrid, etc. without code changes.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM="Virtuagym <noreply@virtuagym.local>"

# ----- Postgres container (used by docker-compose / scripts/run-postgres.sh) -----
POSTGRES_DB=virtuagym
POSTGRES_USER=virtuagym
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
