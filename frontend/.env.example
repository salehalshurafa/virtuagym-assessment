# Copy this file to .env and fill in values for your environment.
# .env is git-ignored. Only variables prefixed with VITE_ are exposed to
# client-side code via `import.meta.env.VITE_*` — anything else is
# Node-side only (e.g. test runner config).

# ----- Backend API base -----
# The FastAPI backend the SPA talks to. axios calls in the stores prepend
# this to every /api/... request. No trailing slash.
#
# Local dev (backend on the same machine):
#   VITE_API_URL=http://localhost:8000
#
# Remote (e.g. backend on a GCP VM — keep the protocol + host + port,
# add HTTPS in real deployments):
#   VITE_API_URL=http://X.X.X.X:8000
VITE_API_URL=http://localhost:8000

# ----- Mailpit (e2e only) -----
# Used by `e2e/invite-user-email.spec.ts` to verify that an admin-create
# user actually triggers a welcome email. The spec hits Mailpit's HTTP
# API to read the message that was queued. Not used by the running app —
# safe to leave at the default if you're not running the email e2e test.
#
# When Mailpit is local:    http://localhost:8025
# When Mailpit is remote:   http://X.X.X.X:8025
MAILPIT_URL=http://localhost:8025
